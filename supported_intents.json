{
    "service": {
        "kaas": {
            "metadata": {
                "category": "paas",
                "page_name_localization": "literal:Managed Kubernetes",
                "page_name": "managedkubernetes",
                "page_icon": "fa-kubernetes"
            },
            "main_form_data": {
                "name": {
                    "type": "name",
                    "user_label": "Cluster name",
                    "default": "my-cluster"
                },
                "nodepools": {
                    "type": "datalist",
                    "user_label": "Nodepools",
                    "item_definition": {
                        "pool_name": {
                            "user_label": "Nodepool Name",
                            "type": "name"
                        },
                        "autoscale": {
                            "user_label": "Autoscale",
                            "type": "boolean",
                            "default": false
                        },
                        "max_nodes": {
                            "user_label": "Max nodes",
                            "type": "slider",
                            "min": 1,
                            "max": 100,
                            "step": 1
                        },
                        "min_nodes": {
                            "user_label": "Min nodes",
                            "type": "slider",
                            "min": 1,
                            "max": 100,
                            "step": 1
                        },
                        "shared_storage_gb": {
                            "user_label": "Shared storage (GB)",
                            "type": "slider",
                            "min": 0,
                            "max": 2048,
                            "step": 16
                        },
                        "specs": {
                            "user_label": "Node specs",
                            "type": "datalist",
                            "item_definition": {
                                "cpu_cores": {
                                    "user_label": "CPU (vCPU)",
                                    "type": "slider",
                                    "min": 1,
                                    "max": 96,
                                    "step": 1
                                },
                                "ram_gb": {
                                    "user_label": "Memory (GB)",
                                    "type": "slider",
                                    "min": 1,
                                    "max": 128,
                                    "step": 1
                                },
                                "storage_gb": {
                                    "user_label": "Storage (GB)",
                                    "type": "slider",
                                    "min": 1,
                                    "max": 2048,
                                    "step": 16
                                },
                                "gpu": {
                                    "user_label": "GPU (count)",
                                    "type": "slider",
                                    "min": 0,
                                    "max": 8,
                                    "step": 1
                                }
                            }
                        }
                    }
                },
                "nodes_subnet": {
                    "user_label": "Nodes subnet",
                    "type": "datalist",
                    "item_definition": {
                        "dhcp": {
                            "user_label": "DHCP",
                            "type": "boolean",
                            "default": true
                        },
                        "ip_range": {
                            "user_label": "IP range",
                            "type": "ip-cidr",
                            "default": "192.170.5.0/24"
                        }
                    }
                },
                "update_policy": {
                    "type": "select",
                    "user_label": "Update policy",
                    "options": [
                        {
                            "user_label": "Always update",
                            "value": "ALWAYS_UPDATE"
                        },
                        {
                            "user_label": "Manual",
                            "value": "MANUAL"
                        }
                    ]
                },
                "kubernetes_version": {
                    "type": "string",
                    "user_label": "Kubernetes Version",
                    "default": "1.34",
                    "regex": "^([1-9]|1[0-9])\\.(0|[1-9][0-9]*)$"
                },
                "controlplane_ha": {
                    "type": "boolean",
                    "user_label": "Control plane HA",
                    "default": false
                },
                "region": {
                    "type": "region",
                    "user_label": "Region"
                },
                "billing_frequency": {
                    "type": "select",
                    "user_label": "Billing Frequency",
                    "default": "month",
                    "options": [
                        {
                            "user_label": "Day",
                            "value": "day"
                        },
                        {
                            "user_label": "Week",
                            "value": "week"
                        },
                        {
                            "user_label": "Month",
                            "value": "month"
                        },
                        {
                            "user_label": "Year",
                            "value": "year"
                        }
                    ]
                }
            },
            "table_layout": [
                {
                    "name": "Name",
                    "localization_key": "cluster_name",
                    "display_type": "text",
                    "json_key": "name"
                },
                {
                    "name": "UUID",
                    "localization_key": "service_id",
                    "display_type": "uuid",
                    "json_key": "service_uuid"
                },
                {
                    "name": "Status",
                    "localization_key": "status",
                    "display_type": "text",
                    "json_key": "status"
                },
                {
                    "name": "Endpoint",
                    "localization_key": "endpoint",
                    "display_type": "text",
                    "json_key": "endpoint"
                },
                {
                    "name": "Region",
                    "localization_key": "location",
                    "display_type": "region",
                    "json_key": "region"
                }
            ],
            "resources": {}
        },
        "kops": {
            "metadata": {
                "category": "paas",
                "page_name_localization": "literal:Kubernetes",
                "page_name": "kubernetes",
                "page_icon": "fa-brands fa-kubernetes"
            },
            "main_form_data": {
                "ip_address": {
                    "type": "target",
                    "user_label": "Target",
                    "target_type": "manual"
                },
                "name": {
                    "type": "name",
                    "user_label": "Cluster Name",
                    "default": "my-cluster",
                    "regex": "[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*"
                },
                "s3_endpoint": {
                    "type": "string",
                    "user_label": "S3 Endpoint",
                    "default": "https://s3.example.com",
                    "regex": "^https://s3"
                },
                "s3_state_bucket": {
                    "type": "string",
                    "user_label": "S3 Bucket",
                    "default": "s3://my-cluster-state-bucket",
                    "regex": "^s3://"
                },
                "s3_access_key_id": {
                    "type": "string",
                    "user_label": "S3 Access Key Id",
                    "regex": "^[A-Z0-9]{20}$"
                },
                "s3_secret_access_key": {
                    "type": "password",
                    "user_label": "S3 Secret Access Key",
                    "regex": "^[A-Za-z0-9/+=]{40}$"
                },
                "node_count": {
                    "type": "number",
                    "user_label": "Node Count",
                    "default": 3,
                    "min": 3,
                    "max": 10
                },
                "node_volume_size": {
                    "type": "number",
                    "user_label": "Node Volume Size (GB)",
                    "default": 64
                },
                "control_plane_volume_size": {
                    "type": "number",
                    "user_label": "Control Plane Volume Size (GB)",
                    "default": 64,
                    "min": 32
                },
                "network_cidr": {
                    "type": "ip-cidr",
                    "user_label": "Network CIDR",
                    "default": "192.168.100.0/24"
                },
                "ssh_public_key": {
                    "type": "textarea",
                    "user_label": "SSH Public Key",
                    "default": "ssh-rsa AAAAB3NzaC1yc2EA..."
                }
            },
            "table_layout": [],
            "resources": {}
        },
        "objectstorage": {
            "metadata": {
                "category": "paas",
                "page_name_localization": "literal:Object Storage",
                "page_name": "objectstorage",
                "page_icon": "fa-solid fa-bucket"
            },
            "main_form_data": {
                "name": {
                    "type": "name",
                    "user_label": "Bucket name",
                    "default": "my-bucket",
                    "regex": "^(?=.{3,24}$)(?!xn--|sthree-|amzn-s3-demo-|aws)(?!.*-s3alias$|.*--ol-s3$|.*--x-s3$|.*--table-s3$)[a-z0-9]([a-z0-9-]*[a-z0-9])?$$"
                },
                "region": {
                    "type": "region",
                    "user_label": "Region"
                },
                "purchasedTB": {
                    "type": "number",
                    "user_label": "PurchasedTB"
                },
                "billing_frequency": {
                    "type": "select",
                    "user_label": "Billing Frequency",
                    "default": "month",
                    "options": [
                        {
                            "user_label": "Day",
                            "value": "day"
                        },
                        {
                            "user_label": "Week",
                            "value": "week"
                        },
                        {
                            "user_label": "Month",
                            "value": "month"
                        },
                        {
                            "user_label": "Year",
                            "value": "year"
                        }
                    ]
                }
            },
            "table_layout": [
                {
                    "name": "Name",
                    "localization_key": "s3/bucket_name",
                    "display_type": "text",
                    "json_key": "name"
                },
                {
                    "name": "UUID",
                    "localization_key": "s3/uuid",
                    "display_type": "uuid",
                    "json_key": "service_uuid"
                },
                {
                    "name": "Endpoint",
                    "localization_key": "s3/endpoint",
                    "display_type": "string",
                    "json_key": "endpoint"
                },
                {
                    "name": "Region",
                    "localization_key": "s3/region",
                    "display_type": "region",
                    "json_key": "region"
                },
                {
                    "name": "Size",
                    "localization_key": "s3/size",
                    "display_type": "byte_sized",
                    "json_key": "active_storage"
                }
            ],
            "resources": {}
        },
        "dbaas": {
            "metadata": {
                "category": "paas",
                "page_name_localization": "literal:Database",
                "page_name": "dbaas",
                "page_icon": "fa-solid fa-database"
            },
            "main_form_data": {
                "name": {
                    "type": "name",
                    "user_label": "Database name",
                    "default": "my-database"
                },
                "region": {
                    "type": "region",
                    "user_label": "Region"
                },
                "engine": {
                    "type": "select",
                    "user_label": "Database engine",
                    "default": "postgres",
                    "options": [
                        {
                            "user_label": "Redis",
                            "value": "redis"
                        },
                        {
                            "user_label": "Mysql",
                            "value": "mysql"
                        },
                        {
                            "user_label": "Sql Server",
                            "value": "sqlserver"
                        },
                        {
                            "user_label": "Postgres",
                            "value": "postgres"
                        }
                    ]
                },
                "backup_time": {
                    "type": "time",
                    "user_label": "Backup time",
                    "format": "HH:mm:ss"
                },
                "disk_size": {
                    "type": "number",
                    "user_label": "Database disk size (GB)",
                    "default": 50,
                    "min": 1
                },
                "password": {
                    "type": "password",
                    "user_label": "password"
                },
                "nodes_number": {
                    "type": "number",
                    "user_label": "nodes number",
                    "default": 1,
                    "min": 1
                }
            },
            "table_layout": [
                {
                    "name": "Name",
                    "localization_key": "name",
                    "display_type": "text",
                    "json_key": "name"
                },
                {
                    "name": "UUID",
                    "localization_key": "service_uuid",
                    "display_type": "uuid",
                    "json_key": "service_uuid"
                },
                {
                    "name": "Region",
                    "localization_key": "region",
                    "display_type": "region",
                    "json_key": "region"
                },
                {
                    "name": "Engine",
                    "localization_key": "engine",
                    "display_type": "text",
                    "json_key": "engine"
                },
                {
                    "name": "Backup time",
                    "localization_key": "backup_time",
                    "display_type": "timestamp",
                    "json_key": "backup_time"
                },
                {
                    "name": "Disk size",
                    "localization_key": "disk_size",
                    "display_type": "byte_sized",
                    "json_key": "disk_size"
                },
                {
                    "name": "Password",
                    "localization_key": "password",
                    "display_type": "text",
                    "json_key": "password"
                },
                {
                    "name": "Nodes number",
                    "localization_key": "nodes_number",
                    "display_type": "text",
                    "json_key": "nodes_number"
                }
            ],
            "resources": {}
        }
    }
}